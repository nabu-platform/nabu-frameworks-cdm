	<field name="newInstance" type="java.lang.Boolean"/>
	<structure definition="nabu.utils.types.ParameterDescription" maxOccurs="unbounded" minOccurs="0" name="initialMasterProperties"/>
	<structure collectionName="teamsTemplates" definition="java.lang.Object" minOccurs="0" name="originalCdmInstance"/>
	<structure definition="nabu.frameworks.cdm.utils.diffResult" maxOccurs="unbounded" name="finalCdmDiffs"/>
	<field name="interested" type="java.lang.Boolean"/>
</structure>
